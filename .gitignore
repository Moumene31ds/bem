.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp compilation folder (https://github.com/nodejs/node-gyp)
build/Release

# Dependency directories for electron-builder
dist

# NestJS cache and build directories
.nest

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

